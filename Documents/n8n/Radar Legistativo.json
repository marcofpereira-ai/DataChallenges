      "parameters": {
        "jsCode": "// ================================================================\n// Mapeia e Formata o HTML do e-mail e texto do Telegram\n// Versão Protegida para Listas Vazias (HTTP Direto no Code)\n// ================================================================\n\nconst todosOsItens = $input.all();\n\nconst emailDestino   = $('Set Config').first().json.EMAIL_DESTINO;\nconst telegramChatId = $('Set Config').first().json.TELEGRAM_CHAT_ID;\nconst temasStr       = $('Set Config').first().json.TEMAS_MONITORADOS;\n\n// 1. Se o nó anterior passou um objeto vazio ou não tem itens reais\nif (!todosOsItens || todosOsItens.length === 0 || !todosOsItens[0].json || Object.keys(todosOsItens[0].json).length === 0) {\n  return [{ \n    json: { \n      sem_dados: true, \n      html_email: `<h2>Bússola Pública</h2><p>Sem novas proposições regulatórias detectadas para os temas monitorados hoje.</p>`,\n      telegram_texto: `🏛️ <b>Bússola Pública</b>\\n\\nSem novas proposições detectadas hoje para os seus temas.`,\n      email_destino: emailDestino, \n      telegram_chat_id: telegramChatId,\n      total_proposicoes: 0,\n      data_relatorio: new Date().toLocaleDateString('pt-BR')\n    } \n  }];\n}\n\n// ... (o restante do código que agrupa por tema segue igual abaixo)"
      },
